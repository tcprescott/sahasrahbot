{
  "permissions": {
    "allow": [
      "mcp__chrome-devtools__take_screenshot",
      "mcp__chrome-devtools__navigate_page",
      "mcp__chrome-devtools__list_console_messages",
      "mcp__chrome-devtools__click",
      "mcp__chrome-devtools__evaluate_script",
      "mcp__chrome-devtools__resize_page",
      "Bash(kill %1)",
      "Bash(pkill -f \"http.server 8777\")",
      "Bash(npm -v)",
      "Bash(echo \"npm: $\\(npm -v 2>/dev/null || echo MISSING\\)\")",
      "Bash(pnpm -v)",
      "Bash(echo \"pnpm: $\\(pnpm -v 2>/dev/null || echo MISSING\\)\")",
      "Bash(yarn -v)",
      "Bash(docker compose exec -T racetime.web python manage.py shell -c ' *)",
      "Bash(poetry run *)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "sentry"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/scripts/enforce_architecture.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/scripts/enforce_no_orm_writes.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python3 .claude/scripts/check_layer_exports.py",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/session-start.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
